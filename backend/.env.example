# =========================
# App
# =========================
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
SWAGGER_ROUTE_PREFIX=/docs
CORS_ORIGIN=http://localhost:5173

# =========================
# Database
# =========================
DATABASE_URL=postgresql://postgres:1234@localhost:5432/datn

# =========================
# Auth / JWT
# =========================
JWT_SECRET=replace-with-a-strong-random-secret
# Access token lifetime (short; silently refreshed via POST /auth/refresh).
JWT_ACCESS_TTL=15m
# Refresh token lifetime = the "force re-login" window (rotating, one-time-use).
JWT_REFRESH_TTL=1d
JWT_ISSUER=typst-platform
JWT_AUDIENCE=typst-platform-users

# =========================
# Email Domain Validation
# =========================
EMAIL_DOMAIN_ADMIN=tlu.edu.vn
EMAIL_DOMAIN_TEACHER=tlu.edu.vn
EMAIL_DOMAIN_STUDENT=student.tlu.edu.vn

# =========================
# Optional Redis / Queue / Cache
# =========================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# =========================
# Typst / Compile
# =========================
TYPST_WORKDIR_ROOT=./var/typst-workdir
COMPILE_STORAGE_ROOT=./var/artifacts
COMPILE_TIMEOUT_MS=30000
MAX_COMPILE_CONCURRENCY=2
COMPILE_WORKER_ENABLED=true
# Compile snapshot byte ceiling. Snapshot adapter throws
# SnapshotTooLargeError (compile job fails cleanly) khi cumulative bytes của
# project vượt mức này — bảo vệ container khỏi OOM với project có nhiều
# binary lớn. Mặc định 256 MB. Tăng nếu user thực sự cần project lớn hơn.
MAX_SNAPSHOT_BYTES=268435456
# Directory containing bundled fonts for server-side Typst compilation.
# Copy fonts from Frontendtluscholareditor/public/fonts/core/ here.
COMPILE_FONT_DIRS=./var/fonts

# =========================
# Upload / File Storage
# =========================
MAX_UPLOAD_SIZE_BYTES=10485760
STORAGE_DRIVER=local
LOCAL_STORAGE_ROOT=./var/storage

# Blob Storage (for artifacts and binary files)
BLOB_STORAGE_DRIVER=local
STORAGE_DIR=./.storage

# Template Storage (for template files)
TEMPLATE_STORAGE_DIR=./storage/templates

# =========================
# S3 / Object Storage (optional)
# =========================
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# =========================
# Google OAuth / SSO (optional)
# =========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# =========================
# LDAP / SSO (optional)
# =========================
LDAP_URL=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_BASE_DN=
LDAP_USER_FILTER=(mail={{email}})
LDAP_START_TLS=false

# =========================
# Collaboration / WebSocket
# =========================
WS_ALLOWED_ORIGIN=http://localhost:5173
COLLAB_SESSION_TTL_SECONDS=86400

# =========================
# Email / SMTP (optional)
# =========================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
SMTP_SECURE=false

# =========================
# Logging / Observability
# =========================
# Pino log level. Production khuyến nghị "warn" để tránh log mỗi request
# (giảm I/O và chi phí log aggregator). Dev giữ "info" để debug dễ.
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# =========================
# Feature Flags (safe defaults)
# =========================
ENABLE_SWAGGER=true
ENABLE_LDAP_SSO=false
ENABLE_COLLABORATION=true
ENABLE_ANALYTICS=true
ENABLE_QUOTA=true

# =========================
# Bibliography Integration
# =========================
# Zotero API base URL (default: https://api.zotero.org)
ZOTERO_API_BASE=https://api.zotero.org

# OpenAlex polite mode email (optional, improves rate limits)
# Provide your email to enable polite mode
OPENALEX_MAILTO=

# Zotero translation-server base URL (self-hosted metadata extractor for the
# "capture a paper from the web" flow). Only required for URL scraping and
# PMID/ISBN lookup — DOI/arXiv capture already works without it via the
# OpenAlex fallback.
#
# `npm run dev` and `npm start` already launch the translation-server alongside
# the backend (via concurrently, label "zotero"). You only need the one-time
# setup below; after that, the normal start command brings the connector up too.
#
# One-time setup, WITHOUT Docker (plain Node.js, needs Node >=20.19/22.13/24 + Git on PATH):
#   git clone --recurse-submodules https://github.com/zotero/translation-server .translation-server
#   cd .translation-server && npm install
#   # if translators don't load, init the submodules from inside .translation-server:
#   git submodule update --init --recursive
# The clone MUST live at backend/.translation-server/ (the launcher assumes that path).
#
# Backend-only (no connector):  npm run dev:backend   /   npm run start:backend
# Connector standalone:         npm run translation-server
#
# (Docker alternative, if you prefer:
#   docker run -d -p 1969:1969 --name translation-server zotero/translation-server)
TRANSLATION_SERVER_URL=http://localhost:1969
