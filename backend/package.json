{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n backend,zotero -c blue,magenta \"npm:dev:backend\" \"npm:translation-server\"",
    "dev:backend": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json && npm run postbuild",
    "postbuild": "node -e \"require('fs').cpSync('src/generated', 'dist/generated', {recursive: true})\"",
    "start": "concurrently -n backend,zotero -c blue,magenta \"npm:start:backend\" \"npm:translation-server\"",
    "start:backend": "node dist/index.js",
    "translation-server": "node scripts/translation-server.mjs",
    "dev:full": "npm run dev",
    "start:full": "npm run start",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "seed:users": "tsx scripts/seed-users.ts",
    "seed:admin": "tsx scripts/seed-admin-data.ts",
    "seed:projects": "tsx scripts/seed-test-projects.ts",
    "seed:templates": "tsx prisma/seed/templates.ts",
    "seed:all": "npm run seed:users && npm run seed:admin && npm run seed:projects && npm run seed:templates",
    "test:unit:projects": "tsx --test src/modules/projects/__tests__/**/*.test.ts",
    "test:unit:project-files": "tsx --test src/modules/project-files/__tests__/**/*.test.ts",
    "test:unit:compile": "tsx --test src/modules/compile/**/__tests__/**/*.test.ts src/shared/storage/__tests__/**/*.test.ts",
    "test:unit:templates": "tsx --test src/modules/templates/__tests__/**/*.test.ts",
    "test:unit:zotero": "tsx --test src/modules/zotero/**/__tests__/**/*.test.ts",
    "test:unit:capture": "tsx --test src/modules/capture/**/__tests__/**/*.test.ts",
    "test:unit:admin": "tsx --test src/modules/admin/**/__tests__/**/*.test.ts",
    "test:unit:openalex": "tsx --test src/modules/openalex/**/__tests__/**/*.test.ts",
    "test:unit:auth": "tsx --test src/modules/auth/**/__tests__/**/*.test.ts",
    "test:unit": "npm run test:unit:projects && npm run test:unit:project-files && npm run test:unit:compile && npm run test:unit:templates && npm run test:unit:zotero && npm run test:unit:capture && npm run test:unit:admin && npm run test:unit:openalex && npm run test:unit:auth",
    "test:api:smoke": "tsx scripts/smoke-test.ts",
    "test:api:health": "tsx scripts/health-check.ts",
    "test:api:login": "tsx scripts/test-login.ts",
    "test:api:auth": "tsx scripts/test-auth.ts",
    "test:api:projects": "tsx scripts/test-projects-api.ts",
    "test:api:projects-zip": "tsx scripts/test-projects-zip-api.ts",
    "test:api:project-files": "tsx scripts/test-project-files-api.ts",
    "test:api:compile": "tsx scripts/test-compile-api.ts",
    "test:api:templates:admin": "tsx scripts/test-templates-admin-api.ts",
    "test:api:templates:public": "tsx scripts/test-templates-public-api.ts",
    "test:api:templates": "npm run test:api:templates:admin && npm run test:api:templates:public",
    "test:api:stage1": "npm run test:api:projects && npm run test:api:project-files",
    "test": "npm run test:unit && npm run test:api:stage1",
    "test:api:admin:faculties": "tsx scripts/test-admin-faculties-api.ts",
    "test:api:admin:departments": "tsx scripts/test-admin-departments-api.ts",
    "test:api:admin:majors": "tsx scripts/test-admin-majors-api.ts",
    "test:api:admin:classes": "tsx scripts/test-admin-classes-api.ts",
    "test:api:admin:teachers": "tsx scripts/test-admin-teachers-api.ts",
    "test:api:admin:students": "tsx scripts/test-admin-students-api.ts",
    "test:api:admin:accounts": "tsx scripts/test-admin-accounts-api.ts",
    "test:api:admin": "npm run test:api:admin:faculties && npm run test:api:admin:departments && npm run test:api:admin:majors && npm run test:api:admin:classes && npm run test:api:admin:teachers && npm run test:api:admin:students && npm run test:api:admin:accounts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@myriaddreamin/typst-ts-node-compiler": "^0.7.0-rc2",
    "@myriaddreamin/typst.ts": "^0.7.0-rc2",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/bcrypt": "^6.0.0",
    "adm-zip": "^0.5.17",
    "archive-wasm": "^2.1.0",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.2.3",
    "fastify": "^5.7.4",
    "fastify-plugin": "^5.1.0",
    "lru-cache": "^11.5.0",
    "pg": "^8.18.0",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5",
    "yaml": "^2.9.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.1",
    "concurrently": "^10.0.3",
    "prisma": "^7.3.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
